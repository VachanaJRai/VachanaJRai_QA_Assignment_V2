{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["responseCode", "brands"],
  "properties": {
    "responseCode": { "type": "integer" },
    "brands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "brand"],
        "properties": {
          "id": { "type": "integer" },
          "brand": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
